# Dockerfile
FROM golang:1.22 AS builder

WORKDIR /app

# Copy go.mod and go.sum first for caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

# Build binary
RUN go build -o user-api ./cmd/main.go

# Final image
FROM debian:bullseye-slim

WORKDIR /app
COPY --from=builder /app/user-api .

EXPOSE 8080
CMD ["./user-api"]
